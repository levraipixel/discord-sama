{
  "name": "discord-sama-lambda",
  "version": "1.0.0",
  "description": "Serverless Discord bot Lambda handler",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "better-sqlite3": "^11.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.1009.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "chrono-node": "^2.7.0",
    "discord-interactions": "^3.4.0"
  }
}
